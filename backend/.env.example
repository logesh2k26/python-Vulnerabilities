# ===========================================
# PyVulnDetect Backend — Environment Variables
# ===========================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

# Backend API secret key (used for X-API-Key header authentication)
API_SECRET_KEY=your_api_secret_key_here

# OpenRouter API key (powers the AI chatbot functionality)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Gemini API key (alternative AI provider)
GEMINI_API_KEY=your_gemini_api_key_here

# ===========================================
# Python Vulnerability Detector - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# Backend API authentication key (clients send this in X-API-Key header)
API_SECRET_KEY=your_api_secret_key_here

# Google Gemini API key (used for AI-powered analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API key (used for chatbot / AI assistant)
OPENROUTER_API_KEY=your_openrouter_api_key_here
